# ============================================================
# POV Guy Publisher — Environment Variables
# ============================================================
# Copy to .env for local dev. NEVER commit .env to git.
# In production, set these as GitHub Actions Secrets.

# ---- Telegram ----
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Numeric chat IDs (NOT @usernames — they may not exist for private channels)
# Get with: curl https://api.telegram.org/bot<TOKEN>/getChat?chat_id=@channelname
TELEGRAM_MAIN_CHAT_ID=-1003773691418
TELEGRAM_STAGING_CHAT_ID=-1003941437847

# ---- Meta (Facebook + Instagram + Threads) ----
# Long-lived Page Access Token. Get from Meta Graph API Explorer or your app's Graph API debug page.
# Required scopes: pages_manage_posts, pages_read_engagement, instagram_content_publish, threads_basic, threads_content_publish
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ID=
META_THREADS_USER_ID=

# Used to refresh the long-lived token periodically (every 50 days)
META_APP_ID=3434219103391689
META_APP_SECRET=

# ---- Content source ----
# Where the content-engine writes daily drops
CONTENT_DROP_DIR=./sample-drop

# ---- Behavior ----
# 'preview' = post only to staging (silent-veto window)
# 'publish' = post to all live platforms (after kill window expires)
# 'dry'     = log only, no API calls
PUBLISH_MODE=dry

# Set to true once Meta App Review approves instagram_content_publish
ENABLE_INSTAGRAM_LIVE=false
